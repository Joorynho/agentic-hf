# Anthropic (MVP2 - CEO/CIO/News LLM agents)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Alpha Vantage (backup market data)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-here
