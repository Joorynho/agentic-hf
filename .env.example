# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Polymarket CLOB API
POLYMARKET_API_KEY=your_polymarket_api_key_here

# Alpaca (MVP4 — paper trading)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# OpenRouter — LLM provider for all agents (CEO, CIO, PM)
# Uses OpenAI-compatible API. Free-tier models available.
# Change OPENROUTER_MODEL to switch models (see src/core/llm.py for fallback list)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemma-3-27b-it:free

# OpenAI (legacy fallback — only used if OPENROUTER_API_KEY is not set)
OPENAI_API_KEY=your_openai_api_key_here

# FRED (MVP3 — macro economic data)
FRED_API_KEY=your_fred_api_key_here
